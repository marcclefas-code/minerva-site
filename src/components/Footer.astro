---
import { directusClient } from '../lib/directus';

const settings = await directusClient.getSiteSettings('en');
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-content">
    <p>&copy; {currentYear} Minerva Holding B.V. All rights reserved.</p>
    <nav class="footer-nav">
      <a href="/privacy">Privacy Policy</a>
      <a href="/terms">Terms of Service</a>
      <a href="/press">Press</a>
      <a href="/investors">Investors</a>
    </nav>
    {settings?.footer_legal && <p class="footer-legal">{settings.footer_legal}</p>}
  </div>
</footer>

<style>
  .site-footer {
    padding: 4rem 2rem;
    border-top: 1px solid rgba(255,255,255,0.1);
    margin-top: 4rem;
  }
  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }
  .footer-nav {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin: 1.5rem 0;
  }
  .footer-nav a {
    opacity: 0.7;
    transition: opacity 0.3s;
  }
  .footer-nav a:hover {
    opacity: 1;
  }
  .footer-legal {
    font-size: 0.875rem;
    opacity: 0.5;
    margin-top: 1rem;
  }
</style>
