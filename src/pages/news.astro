---
import BaseLayout from '../layouts/BaseLayout.astro';
import { directusClient } from '../lib/directus';

const articles = await directusClient.getNewsArticles('en');
---

<BaseLayout title="News" description="Minerva Holding news and updates">
  <section class="news-page">
    <div class="news-header">
      <h1>News & Updates</h1>
      <p class="tagline">Stay informed about Minerva Holding</p>
    </div>

    <div class="news-grid">
      {articles.length > 0 ? (
        articles.map((article) => (
          <article class="news-card">
            {article.cover && (
              <div class="card-image">
                <img src={article.cover} alt={article.title} loading="lazy" />
              </div>
            )}
            <div class="card-content">
              <time class="publish-date">
                {new Date(article.published_date).toLocaleDateString('en-GB', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                })}
              </time>
              <h2>{article.title}</h2>
              {article.excerpt && <p class="excerpt">{article.excerpt}</p>}
              <a href={`/news/${article.slug}`} class="read-more">Read More</a>
            </div>
          </article>
        ))
      ) : (
        <div class="no-news">
          <p>No news articles available at the moment.</p>
          <p>Check back soon for updates.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .news-page {
    padding: 4rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  .news-header {
    text-align: center;
    margin-bottom: 4rem;
  }
  .news-header h1 {
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 300;
  }
  .tagline {
    font-size: 1.25rem;
    opacity: 0.8;
    margin-top: 1rem;
  }
  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 2rem;
  }
  .news-card {
    border: 1px solid rgba(255,255,255,0.1);
    overflow: hidden;
  }
  .card-image img {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }
  .card-content {
    padding: 1.5rem;
  }
  .publish-date {
    font-size: 0.875rem;
    opacity: 0.6;
  }
  .news-card h2 {
    font-size: 1.25rem;
    font-weight: 400;
    margin: 0.75rem 0;
  }
  .excerpt {
    font-size: 0.9375rem;
    line-height: 1.6;
    opacity: 0.8;
    margin-bottom: 1rem;
  }
  .read-more {
    font-size: 0.875rem;
    text-decoration: underline;
    opacity: 0.7;
  }
  .no-news {
    text-align: center;
    padding: 4rem;
    opacity: 0.8;
    grid-column: 1 / -1;
  }
</style>
