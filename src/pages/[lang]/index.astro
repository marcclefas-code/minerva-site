---
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  const locales = ['nl', 'fr', 'de', 'it', 'es', 'zh', 'ja'];
  return locales.map(lang => ({
    params: { lang }
  }));
}

const { lang } = Astro.params;

const langNames: Record<string, string> = {
  nl: 'Nederlands',
  fr: 'Français',
  de: 'Deutsch',
  it: 'Italiano',
  es: 'Español',
  zh: '中文',
  ja: '日本語',
};

const langName = langNames[lang] || lang;
---

<BaseLayout title={`Home - ${langName}`}>
  <section class="hero">
    <div class="hero-content">
      <h1 class="motto">Nulla Mea Credere</h1>
      <p class="tagline">Redefining the Art of Luxury Mobility</p>
    </div>
    <div class="hero-image">
      <img src="/uploads/minervabike.jpg" alt="Minerva Luxury Vehicle" />
    </div>
  </section>

  <section class="teaser-grid">
    <div class="teaser-card">
      <h2>Aegis</h2>
      <p>Coming Soon</p>
      <a href={`/${lang}/aegis`} class="btn">Learn More</a>
    </div>
    <div class="teaser-card">
      <h2>Sovereign</h2>
      <p>Coming Soon</p>
      <a href={`/${lang}/sovereign`} class="btn">Learn More</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 2rem;
  }
  .motto {
    font-size: clamp(2rem, 8vw, 6rem);
    font-weight: 300;
    letter-spacing: 0.1em;
    text-align: center;
  }
  .tagline {
    text-align: center;
    font-size: 1.25rem;
    opacity: 0.8;
    margin-top: 1rem;
  }
  .hero-image img {
    max-width: 100%;
    height: auto;
  }
  .teaser-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    padding: 4rem 2rem;
  }
  .teaser-card {
    padding: 3rem;
    text-align: center;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .teaser-card h2 {
    font-size: 2rem;
    font-weight: 300;
    margin-bottom: 1rem;
  }
  .btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    border: 1px solid currentColor;
    text-decoration: none;
    margin-top: 1rem;
    transition: background 0.3s;
  }
  .btn:hover {
    background: rgba(255,255,255,0.1);
  }
</style>
