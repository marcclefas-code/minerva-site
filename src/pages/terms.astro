---
import BaseLayout from '../layouts/BaseLayout.astro';
import { directusClient } from '../lib/directus';

const doc = await directusClient.getLegalDocument('terms', 'en');
const content = doc?.body || getDefaultTermsContent();

function getDefaultTermsContent() {
  return `
    <h2>Terms of Service</h2>
    <p>Last updated: ${new Date().toLocaleDateString()}</p>
    <h3>1. Acceptance of Terms</h3>
    <p>By accessing and using this website, you accept and agree to be bound by the terms and provisions of this agreement.</p>
    <h3>2. Use of the Website</h3>
    <p>You may use this website only for lawful purposes and in accordance with these Terms of Service.</p>
    <h3>3. Intellectual Property</h3>
    <p>All content on this website, including but not limited to text, graphics, logos, and images, is the property of Minerva Holding B.V. and protected by applicable intellectual property laws.</p>
    <h3>4. Disclaimer</h3>
    <p>The information on this website is provided "as is" without warranties of any kind, either express or implied.</p>
    <h3>5. Limitation of Liability</h3>
    <p>Minerva Holding B.V. shall not be liable for any damages arising from the use of this website.</p>
    <h3>6. Governing Law</h3>
    <p>These Terms of Service shall be governed by and construed in accordance with applicable law.</p>
    <h3>7. Changes to Terms</h3>
    <p>We reserve the right to modify these terms at any time. Changes will be effective immediately upon posting to the website.</p>
    <h3>8. Contact Us</h3>
    <p>If you have questions about these Terms of Service, please contact us at legal@minerva-holding.com.</p>
  `;
}
---

<BaseLayout title="Terms of Service" description="Minerva Holding B.V. Terms of Service">
  <section class="legal-page">
    <div class="legal-content">
      <div set:html={content} />
    </div>
  </section>
</BaseLayout>

<style>
  .legal-page {
    padding: 4rem 2rem;
  }
  .legal-content {
    max-width: 65ch;
    margin: 0 auto;
  }
  .legal-content :global(h2) {
    font-size: 2rem;
    font-weight: 300;
    margin-bottom: 1.5rem;
  }
  .legal-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 400;
    margin: 2rem 0 1rem;
  }
  .legal-content :global(p) {
    line-height: 1.8;
    margin-bottom: 1rem;
  }
</style>
