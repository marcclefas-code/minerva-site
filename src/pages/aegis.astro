---
import BaseLayout from '../layouts/BaseLayout.astro';
import CountdownTimer from '../components/CountdownTimer.astro';
import { directusClient } from '../lib/directus';

const reveal = await directusClient.getProductReveal('aegis', 'en');
const targetDate = reveal?.target_date || '2027-12-01T00:00:00Z';
const headline = reveal?.headline || 'Aegis';
const subline = reveal?.subline || 'The Future of Protection';
const specsHtml = reveal?.specs_html || '';
---

<BaseLayout title={headline} description={subline}>
  <section class="reveal-page">
    <div class="reveal-content">
      <p class="eyebrow">Coming Soon</p>
      <h1>{headline}</h1>
      <p class="subline">{subline}</p>
      
      <div class="countdown-wrapper">
        <CountdownTimer targetDate={targetDate} />
      </div>

      {specsHtml && <div class="specs" set:html={specsHtml} />}

      <div class="teaser-image">
        <img src="/uploads/aegis-teaser.png" alt={`${headline} Preview`} />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .reveal-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
  }
  .reveal-content {
    text-align: center;
    max-width: 800px;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.875rem;
    opacity: 0.6;
  }
  h1 {
    font-size: clamp(3rem, 10vw, 8rem);
    font-weight: 300;
    letter-spacing: 0.05em;
    margin: 1rem 0;
  }
  .subline {
    font-size: 1.5rem;
    opacity: 0.8;
    margin-bottom: 3rem;
  }
  .countdown-wrapper {
    margin: 3rem 0;
  }
  .specs {
    margin: 3rem 0;
    padding: 2rem;
    border-top: 1px solid rgba(255,255,255,0.1);
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .teaser-image img {
    max-width: 100%;
    height: auto;
    margin-top: 2rem;
  }
</style>
